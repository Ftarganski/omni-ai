{
  "name": "omni-ai",
  "version": "0.1.0",
  "description": "Provider-agnostic AI agents and skills framework",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "omni": "node packages/omni-ai/dist/cli/bin.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
