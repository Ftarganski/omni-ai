      "@omni-ai/provider-openai": ["../provider-openai/src/index.ts"],
      "@omni-ai/skills": ["../skills/src/index.ts"],
      "@omni-ai/skills/backend": ["../skills/src/backend/index.ts"],
      "@omni-ai/skills/code": ["../skills/src/code/index.ts"],
      "@omni-ai/skills/fs": ["../skills/src/fs/index.ts"],
      "@omni-ai/skills/frontend": ["../skills/src/frontend/index.ts"],
      "@omni-ai/skills/git": ["../skills/src/git/index.ts"],
      "@omni-ai/skills/http": ["../skills/src/http/index.ts"],
      "@omni-ai/skills/multimodal": ["../skills/src/multimodal/index.ts"],
