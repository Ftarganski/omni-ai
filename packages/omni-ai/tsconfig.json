    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "skipLibCheck": true,
    "paths": {
      "@omni-ai/core": ["../core/src/index.ts"],
      "@omni-ai/cli": ["../cli/src/bin.ts"],
