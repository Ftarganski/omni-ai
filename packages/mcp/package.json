{
  "name": "@omni-ai/mcp",
  "version": "0.1.0",
  "description": "MCP (Model Context Protocol) integration for omni-ai — server and client adapters",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "private": true,
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check src/ test/",
    "format": "biome check --write src/ test/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@omni-ai/core": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
