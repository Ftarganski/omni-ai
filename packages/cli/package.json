{
  "name": "@omni-ai/cli",
  "version": "0.1.0",
  "description": "CLI for omni-ai framework — run agents from the terminal",
  "type": "module",
  "bin": {
    "omni": "./dist/bin.js"
  },
  "main": "./dist/bin.js",
  "scripts": {
    "build": "tsc && node -e \"import('fs').then(fs => fs.chmodSync('dist/bin.js', 0o755))\"",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@omni-ai/core": "workspace:*",
    "@omni-ai/provider-anthropic": "workspace:*",
    "@omni-ai/provider-openai": "workspace:*",
    "@omni-ai/skills-fs": "workspace:*",
    "@omni-ai/skills-code": "workspace:*",
    "@omni-ai/skills-ux": "workspace:*",
    "@omni-ai/memory": "workspace:*",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.0.0",
    "@inquirer/prompts": "^7.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
