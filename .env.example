# ─────────────────────────────────────────────────────────────────────────────
# omni-ai — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the keys for the providers you use.
#
#   cp .env.example .env
#
# Never commit your .env file — it is already listed in .gitignore.
# Only set the keys for providers you actually configure in omni-ai.yaml.
# ─────────────────────────────────────────────────────────────────────────────


# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Required if providers[].type = "anthropic" is set in omni-ai.yaml
#
# How to get: https://console.anthropic.com → API Keys → Create key
# Format: sk-ant-api03-...
#
ANTHROPIC_API_KEY=


# ── OpenAI (GPT) ──────────────────────────────────────────────────────────────
# Required if providers[].type = "openai" is set in omni-ai.yaml
#
# How to get: https://platform.openai.com → API keys → Create new secret key
# Format: sk-proj-... (new) or sk-... (legacy)
#
OPENAI_API_KEY=


# ── GitHub Copilot ────────────────────────────────────────────────────────────
# Required if providers[].type = "copilot" is set in omni-ai.yaml
#
# How to get: https://github.com/settings/tokens → Generate new token (classic)
#   Scopes required: (none — a PAT with no extra scopes is sufficient for Copilot API)
# Format: ghp_... (classic PAT) or github_pat_... (fine-grained PAT)
#
GITHUB_TOKEN=


# ── Google (Gemini) ───────────────────────────────────────────────────────────
# Required if providers[].type = "google" is set in omni-ai.yaml
#
# How to get: https://aistudio.google.com → Get API key → Create API key
# Free tier: gemini-2.0-flash / gemini-1.5-flash — 15 RPM, 1M tokens/day, no card required
# Format: AIza...
#
GOOGLE_API_KEY=


# ── Custom / self-hosted providers ────────────────────────────────────────────
# If you run a self-hosted LLM endpoint compatible with the OpenAI API format
# (e.g., Ollama, LM Studio, vLLM, Azure OpenAI, Groq, Together AI, etc.),
# set the base URL here and reference it in omni-ai.yaml via baseUrl.
#
# Examples:
#   CUSTOM_LLM_BASE_URL=http://localhost:11434/v1          # Ollama
#   CUSTOM_LLM_BASE_URL=https://api.groq.com/openai/v1     # Groq
#   CUSTOM_LLM_BASE_URL=https://<resource>.openai.azure.com # Azure OpenAI
#   CUSTOM_LLM_API_KEY=<your-key-if-required>
#
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
